# Copy to backend/.env and fill in. NEVER commit the real .env.

ENV=dev
DEBUG=true

# Session cookie signing key. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me

# Database (local dev defaults to the docker-compose Postgres on 5433)
DATABASE_URL=postgresql+psycopg2://jobsapp:jobsapp@localhost:5433/jobsapp

# Cloudflare R2 (S3-compatible). For local dev you can point at MinIO.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jobsapp-documents
R2_REGION=auto

# AI backend: claude_code (subscription via CLI) | anthropic_api (pay-per-token key)
AI_BACKEND=claude_code
CLAUDE_BIN=claude
# From `claude setup-token` on the server (tied to the Max subscription). Server-only.
CLAUDE_CODE_OAUTH_TOKEN=
# Empty = CLI default model; set e.g. "opus" to force.
CLAUDE_MODEL=
CLAUDE_TIMEOUT=180

# Only needed if AI_BACKEND=anthropic_api
ANTHROPIC_API_KEY=
