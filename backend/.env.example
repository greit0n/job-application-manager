# Copy to backend/.env and fill in. NEVER commit the real .env.

ENV=dev
DEBUG=true

# Session cookie signing key. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me

# Database (local dev defaults to the docker-compose Postgres on 5433)
DATABASE_URL=postgresql+psycopg2://jobsapp:jobsapp@localhost:5433/jobsapp

# Cloudflare R2 (S3-compatible). For local dev you can point at MinIO.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=jobsapp-documents
R2_REGION=auto

# AI backend: codex_cli (Codex CLI with ChatGPT/Codex subscription login) | claude_code (rollback)
AI_BACKEND=codex_cli
AI_TIMEOUT=180
CODEX_BIN=codex
# Empty = Codex CLI default model.
CODEX_MODEL=
# Empty = Codex CLI default ~/.codex. On prod set /home/jobsapp/.codex.
CODEX_HOME=

# Claude Code rollback only. Leave commented unless AI_BACKEND=claude_code.
# CLAUDE_BIN=claude
# From `claude setup-token` if the rollback backend is re-enabled. Server-only.
# CLAUDE_CODE_OAUTH_TOKEN=
# Empty = CLI default model; set e.g. "claude-opus-4-8" (or "opus") to pin.
# CLAUDE_MODEL=
# CLI reasoning effort: low | medium | high | xhigh | max (empty = default).
# CLAUDE_EFFORT=
